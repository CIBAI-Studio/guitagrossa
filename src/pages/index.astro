---
import Layout from '../layouts/Layout.astro';
import integrantsData from '../data/integrants.json';

const allImages = [
  { src: '/images/slider-01.webp', alt: 'La Guita Grossa a la Patum de Berga' },
  { src: '/images/slider-02.webp', alt: 'Foc i festa nocturna' },
  { src: '/images/slider-03.webp', alt: 'La comparsa en plena actuació' },
  { src: '/images/slider-04.webp', alt: 'Fuets encesos a la plaça' },
  { src: '/images/slider-05.webp', alt: 'Nit de Patum' },
  { src: '/images/slider-06.webp', alt: 'Tradició i festa' },
  { src: '/images/galeria-01.webp', alt: 'La Guita Grossa durant la Patum' },
  { src: '/images/galeria-02.webp', alt: 'Foc i festa a la plaça Sant Pere' },
  { src: '/images/galeria-03.webp', alt: 'La comparsa en acció' },
  { src: '/images/galeria-04.webp', alt: 'Integrants portant la Guita' },
  { src: '/images/galeria-05.webp', alt: 'Fuets encesos de la Guita Grossa' },
  { src: '/images/galeria-06.webp', alt: 'La Patum de Berga' },
  { src: '/images/galeria-07.webp', alt: 'Nit de foc a Berga' },
  { src: '/images/galeria-08.webp', alt: 'Tradició centenària de la Guita' },
  { src: '/images/historia-01.webp', alt: 'Orígens de la Guita Grossa' },
  { src: '/images/historia-02.webp', alt: 'Forma de la Guita Grossa' },
  { src: '/images/historia-03.webp', alt: 'La Guita Grossa avui' },
  { src: '/images/historia-04.webp', alt: 'Tradició de la Guita Grossa' },
  { src: '/images/about-patum.webp', alt: 'La Patum de Berga, foc i tradició' },
];

const timeline = [
  {
    year: 'Orígens',
    title: 'La Mulaguita, Mulafera o Mulassa',
    text: 'La Guita Grossa és una figura mitològica de reminiscències infernals, probablement heretada de les antigues processons del Corpus Christi. Coneguda inicialment com a Mulaguita, Mulafera o Mulassa, sembla que el seu origen era el d\'una simple mula que, amb el temps, va anar transformant-se: el coll es va allargar progressivament fins a permetre-li atacar els espectadors que s\'arreceraven a la barana de la plaça Sant Pere.',
    image: '/images/historia-01.webp',
  },
  {
    year: 'Forma',
    title: 'Cos de mula, coll de girafa',
    text: 'La Guita Grossa es caracteritza per la seva forma zoomòrfica peculiar: cos de mula, coll desproporcionadament llarg —que en alguns documents berguedans del final del segle XIX apareix comparat al d\'una girafa— i un cap ferèstec que recorda el d\'un drac. Dins la Patum s\'ha associat tradicionalment a la representació del Mal i les forces malignes.',
    image: '/images/historia-02.webp',
  },
  {
    year: 'Avui',
    title: 'La Guita Grossa, icona de foc',
    text: 'La Guita Grossa és avui una de les comparses més emblemàtiques i reconegudes de la Patum. La seva missió és córrer darrera el públic amb tres fuets encesos a la boca, generant aquella barreja d\'eufòria i enrenou que caracteritza la festa. Generació rere generació, els seus integrants mantenen viva la flama d\'aquesta tradició ancestral.',
    image: '/images/historia-03.webp',
  },
  {
    year: 'Tradició',
    title: 'Més de quatre metres d\'alçada',
    text: 'La Guita Grossa és portada per un grup de persones que li donen vida des de sota: algú la guia des del davant, mentre que un altre, des de l\'interior, maniobra el cap al cim d\'un coll que supera els quatre metres d\'alçada. El resultat és una criatura viva, imprevisible i majestuosa enmig del foc.',
    image: '/images/historia-04.webp',
  },
];
---

<Layout title="La Guita Grossa — La Patum de Berga">

  <!-- ═══════════════════════════════════════════ HERO ═══════════════════════════════════════════ -->
  <section id="inici" class="relative min-h-svh flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/hero-patum.webp"
        alt="La Guita Grossa durant la Patum de Berga"
        class="absolute inset-0 w-full h-full object-cover scale-105"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/20 to-bg"></div>
    </div>

    <div class="relative z-10 text-center px-4 max-w-3xl">
      <div class="glass-prominent rounded-[--radius-xl] px-8 py-12 sm:px-12 sm:py-16">
        <img
          src="/images/logo-guitagrossa.webp"
          alt="Escut La Guita Grossa"
          class="w-20 h-20 mx-auto mb-6 drop-shadow-lg"
        />
        <p class="text-primary text-[0.6875rem] font-semibold tracking-[0.1em] uppercase mb-4">
          Comparsa de La Patum de Berga
        </p>
        <h1 class="text-[clamp(2.5rem,7vw,5.5rem)] font-bold text-text leading-[1.1]">
          La Guita Grossa
        </h1>
        <div class="mt-6 h-px w-24 bg-primary/40 mx-auto"></div>
        <p class="mt-6 text-text-muted text-lg sm:text-xl max-w-xl mx-auto text-balance">
          Patrimoni Immaterial de la Humanitat per la UNESCO
        </p>
        <a
          href="#historia"
          class="inline-flex items-center gap-2 mt-10 glass-btn px-8 py-3 rounded-full text-sm font-medium text-text tracking-[0.08em] uppercase"
        >
          Descobreix
          <svg class="w-4 h-4 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ HISTÒRIA ═══════════════════════════════════════════ -->
  <section id="historia" class="relative py-20 sm:py-32">
    <div class="absolute inset-0 bg-gradient-to-b from-bg via-bg/95 to-bg"></div>
    <div class="relative mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">

      <div class="text-center mb-16">
        <p class="text-primary text-[0.6875rem] font-semibold tracking-[0.1em] uppercase">La nostra</p>
        <h2 class="text-[clamp(2rem,4vw,3.5rem)] font-bold text-text mt-3">Història</h2>
        <div class="mt-4 h-px w-16 bg-primary/30 mx-auto"></div>
      </div>

      <div class="space-y-12">
        {timeline.map((item, i) => (
          <div class:list={[
            'glass-card rounded-[--radius-xl] overflow-hidden',
            'grid md:grid-cols-2 gap-0',
            i % 2 !== 0 ? 'md:[direction:rtl]' : '',
          ]}>
            <div class="aspect-[4/3] md:aspect-auto overflow-hidden">
              <img
                src={item.image}
                alt={item.title}
                class="w-full h-full object-cover"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="p-8 sm:p-10 flex flex-col justify-center md:[direction:ltr]">
              <span class="inline-block w-fit text-[0.6875rem] font-semibold tracking-[0.1em] uppercase text-primary glass-btn-primary px-4 py-1.5 rounded-full mb-4">
                {item.year}
              </span>
              <h3 class="text-[1.5rem] font-bold text-text mb-4">{item.title}</h3>
              <p class="text-text-muted text-[0.9375rem] leading-relaxed">{item.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ GALERIA ═══════════════════════════════════════════ -->
  <section id="galeria" class="relative py-20 sm:py-32">
    <div class="absolute inset-0 bg-gradient-to-b from-bg via-[#121212] to-bg"></div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

      <div class="text-center mb-16">
        <p class="text-primary text-[0.6875rem] font-semibold tracking-[0.1em] uppercase">Moments</p>
        <h2 class="text-[clamp(2rem,4vw,3.5rem)] font-bold text-text mt-3">Galeria</h2>
        <div class="mt-4 h-px w-16 bg-primary/30 mx-auto"></div>
      </div>

      <div class="columns-2 sm:columns-3 lg:columns-4 gap-3 space-y-3">
        {allImages.map((img) => (
          <div class="break-inside-avoid group">
            <div class="rounded-[--radius-lg] overflow-hidden glass-card">
              <img
                src={img.src}
                alt={img.alt}
                class="w-full h-auto object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
                decoding="async"
              />
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ INTEGRANTS ═══════════════════════════════════════════ -->
  <section id="integrants" class="relative py-20 sm:py-32">
    <div class="absolute inset-0 bg-gradient-to-b from-bg via-bg/95 to-bg"></div>
    <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">

      <div class="text-center mb-16">
        <p class="text-primary text-[0.6875rem] font-semibold tracking-[0.1em] uppercase">La nostra gent</p>
        <h2 class="text-[clamp(2rem,4vw,3.5rem)] font-bold text-text mt-3">Integrants</h2>
        <div class="mt-4 h-px w-16 bg-primary/30 mx-auto"></div>
        <p class="mt-6 text-text-muted max-w-lg mx-auto">
          Les persones que fan possible que La Guita Grossa surti al carrer any rere any.
        </p>
      </div>

      {integrantsData.categories.map((category) => (
        <div class="mb-16 last:mb-0">
          <div class="flex items-center gap-4 mb-8">
            <h3 class="glass-btn-primary px-5 py-2 rounded-full text-[0.75rem] tracking-[0.1em] uppercase text-text font-semibold whitespace-nowrap">
              {category.title}
            </h3>
            <div class="flex-1 h-px bg-white/8"></div>
            <span class="text-xs text-text-muted glass px-3 py-1 rounded-full">
              {category.members.length} {category.members.length === 1 ? 'membre' : 'membres'}
            </span>
          </div>

          <div class="grid grid-cols-[repeat(auto-fill,minmax(200px,1fr))] gap-4">
            {category.members.map((member) => (
              <article class="glass-card rounded-[--radius-xl] p-5 transition-all duration-300 hover:scale-[1.03] hover:shadow-[--shadow-glow-red] group cursor-default">
                <div class="w-12 h-12 rounded-full glass-prominent flex items-center justify-center mb-4">
                  <svg class="w-6 h-6 text-text-muted/50" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
                  </svg>
                </div>

                <h4 class="text-[1rem] font-semibold text-text leading-tight group-hover:text-primary transition-colors">
                  {member.name}
                </h4>
                {member.years !== null && (
                  <p class="text-text-muted text-[0.8125rem] mt-2">
                    {member.years} anys de guita
                  </p>
                )}
              </article>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ CONTACTE ═══════════════════════════════════════════ -->
  <section id="contacte" class="relative py-20 sm:py-32">
    <div class="absolute inset-0 bg-gradient-to-b from-bg via-[#121212] to-bg"></div>
    <div class="relative mx-auto max-w-xl px-4 sm:px-6 lg:px-8">

      <div class="text-center mb-12">
        <p class="text-primary text-[0.6875rem] font-semibold tracking-[0.1em] uppercase">Escriu-nos</p>
        <h2 class="text-[clamp(2rem,4vw,3.5rem)] font-bold text-text mt-3">Contacte</h2>
        <div class="mt-4 h-px w-16 bg-primary/30 mx-auto"></div>
      </div>

      <div class="glass-card rounded-[--radius-xl] p-8 sm:p-10">
        <form
          id="contact-form"
          action="https://airform.io/comparsa@guitagrossa.com"
          method="POST"
          class="space-y-6"
        >
          <div>
            <label for="name" class="block text-sm font-medium text-text mb-2">Nom</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              autocomplete="name"
              placeholder="El teu nom"
              class="w-full px-4 py-3 glass-input rounded-[--radius-md] text-text placeholder:text-text-muted/50 focus:outline-none focus:border-primary/40 focus:shadow-[0_0_0_2px_rgba(196,30,58,0.15)] transition-all"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-text mb-2">Correu electrònic</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              placeholder="nom@exemple.cat"
              class="w-full px-4 py-3 glass-input rounded-[--radius-md] text-text placeholder:text-text-muted/50 focus:outline-none focus:border-primary/40 focus:shadow-[0_0_0_2px_rgba(196,30,58,0.15)] transition-all"
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-text mb-2">Missatge</label>
            <textarea
              id="message"
              name="message"
              required
              rows="5"
              placeholder="Escriu el teu missatge..."
              class="w-full px-4 py-3 glass-input rounded-[--radius-md] text-text placeholder:text-text-muted/50 focus:outline-none focus:border-primary/40 focus:shadow-[0_0_0_2px_rgba(196,30,58,0.15)] transition-all resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full glass-btn-primary px-6 py-3.5 text-text text-sm font-semibold tracking-[0.08em] uppercase rounded-full transition-all"
          >
            Enviar missatge
          </button>
        </form>

        <div id="form-success" class="hidden mt-6 glass p-4 rounded-[--radius-md] text-center border-secondary/20">
          <p class="text-secondary font-medium">Missatge enviat correctament!</p>
          <p class="text-text-muted text-sm mt-1">Et respondrem el més aviat possible.</p>
        </div>

        <div id="form-error" class="hidden mt-6 glass-crimson p-4 rounded-[--radius-md] text-center">
          <p class="text-primary font-medium">Error en enviar el missatge.</p>
          <p class="text-text-muted text-sm mt-1">Si us plau, torna-ho a provar més tard.</p>
        </div>
      </div>
    </div>
  </section>

</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success')!;
  const error = document.getElementById('form-error')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    success.classList.add('hidden');
    error.classList.add('hidden');

    const data = new URLSearchParams(new FormData(form) as any);

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: data,
      });

      if (response.ok) {
        form.reset();
        success.classList.remove('hidden');
      } else {
        error.classList.remove('hidden');
      }
    } catch {
      error.classList.remove('hidden');
    }
  });
</script>
