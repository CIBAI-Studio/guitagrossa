---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contacte — La Guita Grossa"
  description="Contacta amb La Guita Grossa de La Patum de Berga. Envia'ns un missatge."
>
  <!-- Header -->
  <section class="pt-28 pb-16 bg-guita-dark">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-guita-gold text-sm tracking-[0.2em] uppercase font-medium">Escriu-nos</p>
      <h1 class="font-display text-4xl sm:text-5xl md:text-6xl text-white mt-3">Contacte</h1>
      <div class="mt-6 h-px w-16 bg-guita-gold/30 mx-auto"></div>
    </div>
  </section>

  <!-- Form -->
  <section class="py-16 sm:py-20 bg-guita-cream">
    <div class="mx-auto max-w-xl px-4 sm:px-6 lg:px-8">
      <form
        id="contact-form"
        action="https://formspree.io/f/PLACEHOLDER"
        method="POST"
        class="space-y-6"
      >
        <div>
          <label for="name" class="block text-sm font-medium text-guita-dark mb-2">
            Nom
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            autocomplete="name"
            placeholder="El teu nom"
            class="w-full px-4 py-3 bg-white border border-guita-dark/10 rounded-lg text-guita-dark placeholder:text-guita-dark/30 focus:outline-none focus:ring-2 focus:ring-guita-red/30 focus:border-guita-red/50 transition-colors"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-guita-dark mb-2">
            Correu electrònic
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            placeholder="nom@exemple.cat"
            class="w-full px-4 py-3 bg-white border border-guita-dark/10 rounded-lg text-guita-dark placeholder:text-guita-dark/30 focus:outline-none focus:ring-2 focus:ring-guita-red/30 focus:border-guita-red/50 transition-colors"
          />
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-guita-dark mb-2">
            Missatge
          </label>
          <textarea
            id="message"
            name="message"
            required
            rows="5"
            placeholder="Escriu el teu missatge..."
            class="w-full px-4 py-3 bg-white border border-guita-dark/10 rounded-lg text-guita-dark placeholder:text-guita-dark/30 focus:outline-none focus:ring-2 focus:ring-guita-red/30 focus:border-guita-red/50 transition-colors resize-none"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full px-6 py-3 bg-guita-red text-white text-sm tracking-wider uppercase rounded-lg hover:bg-guita-red-light focus:outline-none focus:ring-2 focus:ring-guita-red/50 focus:ring-offset-2 focus:ring-offset-guita-cream transition-colors"
        >
          Enviar missatge
        </button>
      </form>

      <!-- Success message -->
      <div id="form-success" class="hidden mt-6 p-4 bg-guita-green/10 border border-guita-green/20 rounded-lg text-center">
        <p class="text-guita-green font-medium">Missatge enviat correctament!</p>
        <p class="text-guita-green/70 text-sm mt-1">Et respondrem el més aviat possible.</p>
      </div>

      <!-- Error message -->
      <div id="form-error" class="hidden mt-6 p-4 bg-guita-red/10 border border-guita-red/20 rounded-lg text-center">
        <p class="text-guita-red font-medium">Error en enviar el missatge.</p>
        <p class="text-guita-red/70 text-sm mt-1">Si us plau, torna-ho a provar més tard.</p>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success')!;
  const error = document.getElementById('form-error')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    success.classList.add('hidden');
    error.classList.add('hidden');

    const data = new FormData(form);

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' },
      });

      if (response.ok) {
        form.reset();
        success.classList.remove('hidden');
      } else {
        error.classList.remove('hidden');
      }
    } catch {
      error.classList.remove('hidden');
    }
  });
</script>
