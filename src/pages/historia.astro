---
import Layout from '../layouts/Layout.astro';

const timeline = [
  {
    year: 'Orígens',
    title: 'Els inicis de La Guita',
    text: 'La Guita Grossa és una de les comparses més emblemàtiques de La Patum de Berga, festa declarada Patrimoni Immaterial de la Humanitat per la UNESCO l\'any 2005. La seva presència a la festa es remunta a segles d\'història i tradició.',
  },
  {
    year: 'La Patum',
    title: 'Foc, música i tradició',
    text: 'La Patum és la festa major de la ciutat de Berga, al Berguedà. Celebrada durant la setmana de Corpus Christi, és una festa ancestral de foc, música i tradició que atrau milers de visitants cada any.',
  },
  {
    year: 'UNESCO',
    title: 'Patrimoni de la Humanitat',
    text: 'L\'any 2005, la UNESCO va declarar La Patum de Berga Obra Mestra del Patrimoni Oral i Immaterial de la Humanitat, reconeixent el valor excepcional d\'aquesta celebració centenària.',
  },
  {
    year: 'Avui',
    title: 'Tradició viva',
    text: 'Generació rere generació, els membres de La Guita Grossa han mantingut viva la flama d\'aquesta tradició centenària. Amb orgull i dedicació, cada any la comparsa surt al carrer per fer vibrar Berga.',
  },
];
---

<Layout
  title="Història — La Guita Grossa"
  description="La història de La Guita Grossa, una de les comparses més emblemàtiques de La Patum de Berga."
>
  <!-- Hero -->
  <section class="relative pt-28 pb-16 sm:pb-20">
    <div class="absolute inset-0 bg-[#2D2D2D]"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-overlay to-bg"></div>
    <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-primary text-[0.6875rem] font-semibold tracking-[0.08em] uppercase">La nostra</p>
      <h1 class="text-[clamp(2.5rem,6vw,5rem)] font-bold text-text mt-3">Història</h1>
      <div class="mt-6 h-px w-16 bg-primary/30 mx-auto"></div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="py-16 sm:py-24 bg-bg">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 relative">
      <!-- Vertical line -->
      <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px bg-primary/30 md:-translate-x-px"></div>

      {timeline.map((item, i) => (
        <div class:list={[
          'relative grid md:grid-cols-2 gap-6 md:gap-12 mb-16 last:mb-0',
          i % 2 === 0 ? '' : 'md:[direction:rtl]',
        ]}>
          <!-- Dot -->
          <div class="absolute left-4 md:left-1/2 top-0 w-3 h-3 rounded-full bg-primary -translate-x-1/2 ring-4 ring-bg z-10"></div>

          <!-- Content card -->
          <div class:list={[
            'ml-10 md:ml-0 glass rounded-[--radius-lg] p-6',
            i % 2 === 0 ? 'md:text-right' : '',
            'md:[direction:ltr]',
          ]}>
            <span class="inline-block text-[0.6875rem] font-semibold tracking-[0.08em] uppercase text-primary bg-primary/10 px-3 py-1 rounded-full mb-3">
              {item.year}
            </span>
            <h3 class="text-[1.25rem] font-semibold text-text mb-3">{item.title}</h3>
            <p class="text-text-muted text-[0.875rem] leading-relaxed">{item.text}</p>
            <p class="text-text-muted/50 text-xs mt-3 italic">Text pendent de confirmació pel client.</p>
          </div>

          <!-- Image placeholder -->
          <div class:list={[
            'hidden md:block ml-10 md:ml-0 md:[direction:ltr]',
          ]}>
            <div class="aspect-[4/3] rounded-[--radius-lg] overflow-hidden shadow-[--shadow-sm]">
              <div class="w-full h-full bg-gradient-to-br from-bg to-[#2D2D2D] flex items-center justify-center">
                <span class="text-text-muted text-sm">Foto — pendent</span>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Gallery grid -->
  <section class="py-16 sm:py-24 bg-bg border-t border-border">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-[clamp(1.75rem,3.5vw,2.75rem)] font-semibold text-text text-center mb-10">
        Galeria històrica
      </h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        {Array.from({ length: 8 }).map((_, i) => (
          <div class="aspect-square rounded-[--radius-lg] overflow-hidden shadow-[--shadow-sm]">
            <div class="w-full h-full bg-gradient-to-br from-surface to-bg flex items-center justify-center">
              <span class="text-text-muted text-xs">Foto {i + 1}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
