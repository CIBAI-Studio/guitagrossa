---
import Layout from '../layouts/Layout.astro';

const timeline = [
  {
    year: 'Orígens',
    title: 'La Mulaguita, Mulafera o Mulassa',
    text: 'La Guita Grossa és una figura mitològica de reminiscències infernals, probablement heretada de les antigues processons del Corpus Christi. Coneguda inicialment com a Mulaguita, Mulafera o Mulassa, sembla que el seu origen era el d\'una simple mula que, amb el temps, va anar transformant-se: el coll es va allargar progressivament fins a permetre-li atacar els espectadors que s\'arreceraven a la barana de la plaça Sant Pere.',
    image: '/images/historia-01.webp',
  },
  {
    year: 'Forma',
    title: 'Cos de mula, coll de girafa',
    text: 'Les Guites de la Patum es caracteritzen per la seva forma zoomòrfica peculiar: cos de mula, coll desproporcionadament llarg —que en alguns documents berguedans del final del segle XIX apareix comparat al d\'una girafa— i un cap ferèstec que recorda el d\'un drac. Quina era la seva funció simbòlica en les processons medievals del Corpus és avui dia desconeguda, però dins la Patum s\'ha associat tradicionalment a la representació del Mal i les forces malignes.',
    image: '/images/historia-02.webp',
  },
  {
    year: 'Avui',
    title: 'Dues Guites: la Grossa i la Xica',
    text: 'Avui, a la Patum conviuen dues Guites: la Grossa i la Xica, també anomenada Boja. La seva missió és córrer darrera el públic amb tres fuets encesos a la boca, generant aquella barreja d\'eufòria i enrenou que caracteritza la festa.',
    image: '/images/historia-03.webp',
  },
  {
    year: 'Tradició',
    title: 'Més de quatre metres d\'alçada',
    text: 'Cada Guita és portada per un grup de persones que li donen vida des de sota: algú la guia des del davant, mentre que un altre, des de l\'interior, maniobra el cap al cim d\'un coll que, en el cas de la Guita Grossa, supera els quatre metres d\'alçada.',
    image: '/images/historia-04.webp',
  },
];

const galeriaImages = [
  { src: '/images/galeria-01.webp', alt: 'La Guita Grossa durant la Patum' },
  { src: '/images/galeria-02.webp', alt: 'Foc i festa a la plaça Sant Pere' },
  { src: '/images/galeria-03.webp', alt: 'La comparsa en acció' },
  { src: '/images/galeria-04.webp', alt: 'Integrants portant la Guita' },
  { src: '/images/galeria-05.webp', alt: 'Fuets encesos de la Guita Grossa' },
  { src: '/images/galeria-06.webp', alt: 'La Patum de Berga' },
  { src: '/images/galeria-07.webp', alt: 'Nit de foc a Berga' },
  { src: '/images/galeria-08.webp', alt: 'Tradició centenària de la Guita' },
];
---

<Layout
  title="Història — La Guita Grossa"
  description="La història de La Guita Grossa, una de les comparses més emblemàtiques de La Patum de Berga."
>
  <!-- Hero -->
  <section class="relative pt-28 pb-16 sm:pb-20">
    <div class="absolute inset-0 bg-[#2D2D2D]"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-overlay to-bg"></div>
    <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-primary text-[0.6875rem] font-semibold tracking-[0.08em] uppercase">La nostra</p>
      <h1 class="text-[clamp(2.5rem,6vw,5rem)] font-bold text-text mt-3">Història</h1>
      <div class="mt-6 h-px w-16 bg-primary/30 mx-auto"></div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="py-16 sm:py-24 bg-bg">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 relative">
      <!-- Vertical line -->
      <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px bg-primary/30 md:-translate-x-px"></div>

      {timeline.map((item, i) => (
        <div class:list={[
          'relative grid md:grid-cols-2 gap-6 md:gap-12 mb-16 last:mb-0',
          i % 2 === 0 ? '' : 'md:[direction:rtl]',
        ]}>
          <!-- Dot -->
          <div class="absolute left-4 md:left-1/2 top-0 w-3 h-3 rounded-full bg-primary -translate-x-1/2 ring-4 ring-bg z-10"></div>

          <!-- Content card -->
          <div class:list={[
            'ml-10 md:ml-0 glass rounded-[--radius-lg] p-6',
            i % 2 === 0 ? 'md:text-right' : '',
            'md:[direction:ltr]',
          ]}>
            <span class="inline-block text-[0.6875rem] font-semibold tracking-[0.08em] uppercase text-primary bg-primary/10 px-3 py-1 rounded-full mb-3">
              {item.year}
            </span>
            <h3 class="text-[1.25rem] font-semibold text-text mb-3">{item.title}</h3>
            <p class="text-text-muted text-[0.875rem] leading-relaxed">{item.text}</p>
          </div>

          <!-- Image -->
          <div class:list={[
            'hidden md:block ml-10 md:ml-0 md:[direction:ltr]',
          ]}>
            <div class="aspect-[4/3] rounded-[--radius-lg] overflow-hidden shadow-[--shadow-sm]">
              <img
                src={item.image}
                alt={item.title}
                class="w-full h-full object-cover"
                loading="lazy"
                decoding="async"
              />
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Gallery grid -->
  <section class="py-16 sm:py-24 bg-bg border-t border-border">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-[clamp(1.75rem,3.5vw,2.75rem)] font-semibold text-text text-center mb-10">
        Galeria històrica
      </h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        {galeriaImages.map((img) => (
          <div class="aspect-square rounded-[--radius-lg] overflow-hidden shadow-[--shadow-sm]">
            <img
              src={img.src}
              alt={img.alt}
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
