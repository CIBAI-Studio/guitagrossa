---
---

<div
  id="music-player"
  class="fixed bottom-6 right-6 z-[300] glass-crimson rounded-full shadow-[--shadow-md] transition-all duration-300"
>
  <button
    id="music-toggle"
    class="flex items-center gap-3 px-5 py-3 text-text hover:text-primary transition-colors"
    aria-label="Pausar música"
    type="button"
  >
    <svg
      id="icon-play"
      class="w-5 h-5 shrink-0 hidden"
      fill="currentColor"
      viewBox="0 0 24 24"
      aria-hidden="true"
    >
      <path d="M8 5v14l11-7z" />
    </svg>
    <svg
      id="icon-pause"
      class="w-5 h-5 shrink-0"
      fill="currentColor"
      viewBox="0 0 24 24"
      aria-hidden="true"
    >
      <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z" />
    </svg>
    <span
      id="music-label"
      class="text-xs font-semibold tracking-[0.06em] uppercase whitespace-nowrap"
    >
      ♪ Reproduint
    </span>
  </button>

  <audio id="audio-player" loop preload="auto">
    <source src="/audio/ambient.mp3" type="audio/mpeg" />
  </audio>
</div>

<script>
  const toggle = document.getElementById('music-toggle')!;
  const audio = document.getElementById('audio-player') as HTMLAudioElement;
  const iconPlay = document.getElementById('icon-play')!;
  const iconPause = document.getElementById('icon-pause')!;
  const label = document.getElementById('music-label')!;

  let playing = false;

  function play() {
    audio.play().then(() => {
      playing = true;
      iconPlay.classList.add('hidden');
      iconPause.classList.remove('hidden');
      label.textContent = '♪ Reproduint';
      toggle.setAttribute('aria-label', 'Pausar música');
    }).catch(() => {});
  }

  function pause() {
    audio.pause();
    playing = false;
    iconPlay.classList.remove('hidden');
    iconPause.classList.add('hidden');
    label.textContent = '♪ Reproduir';
    toggle.setAttribute('aria-label', 'Reproduir música');
  }

  toggle.addEventListener('click', () => {
    if (playing) {
      pause();
    } else {
      play();
    }
  });

  // Autoplay on first user interaction
  function autoplayOnInteraction() {
    if (!playing) {
      play();
    }
    document.removeEventListener('click', autoplayOnInteraction);
    document.removeEventListener('scroll', autoplayOnInteraction);
    document.removeEventListener('touchstart', autoplayOnInteraction);
  }

  // Try direct autoplay first
  audio.volume = 0.4;
  audio.play().then(() => {
    playing = true;
  }).catch(() => {
    // Browser blocked autoplay — wait for first interaction
    iconPlay.classList.remove('hidden');
    iconPause.classList.add('hidden');
    label.textContent = '♪ Reproduir';
    document.addEventListener('click', autoplayOnInteraction, { once: true });
    document.addEventListener('scroll', autoplayOnInteraction, { once: true });
    document.addEventListener('touchstart', autoplayOnInteraction, { once: true });
  });
</script>
