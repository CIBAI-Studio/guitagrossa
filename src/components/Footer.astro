    <p class="text-sm text-text-muted">
      Dissenyat amb <span class="text-primary" aria-label="amor">❤</span> per
      <a
        href="https://cibai.studio"
        target="_blank"
        rel="noopener noreferrer"
        class="text-text hover:text-primary transition-colors"
      >
        CIBAI Studio
      </a>
    </p>
    <p class="text-xs text-text-muted/60 mt-3">&copy; {year} La Guita Grossa. Tots els drets reservats.</p>
  </div>
</footer>
