---
const year = new Date().getFullYear();
---

<footer class="bg-guita-dark text-white/60 py-12">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center gap-6 text-center">
      <p class="font-display text-xl text-guita-gold">La Guita Grossa</p>
      <p class="text-sm">La Patum de Berga — Patrimoni Immaterial de la Humanitat</p>
      <div class="h-px w-16 bg-white/10"></div>
      <p class="text-xs">
        Dissenyat amb <span class="text-guita-red-light" aria-label="amor">❤</span> per
        <a
          href="https://cibai.studio"
          target="_blank"
          rel="noopener noreferrer"
          class="text-white/80 underline underline-offset-2 decoration-white/20 hover:text-white hover:decoration-white/40 transition-colors"
        >
          CIBAI Studio
        </a>
      </p>
      <p class="text-xs text-white/30">&copy; {year} La Guita Grossa. Tots els drets reservats.</p>
    </div>
  </div>
</footer>
